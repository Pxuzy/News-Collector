# News-Collector Docker defaults

# Local timezone. The scheduler treats Asia/Shanghai as UTC+8; set UTC for UTC mode.
TZ=Asia/Shanghai

# Scheduled collection times, comma-separated HH:MM. These runs do not force sources;
# source_state.next_run_at prevents redundant refreshes inside the window.
COLLECT_SCHEDULE=08:30,12:30,18:30,22:30
COLLECT_PARALLEL=8
COLLECT_FORCE=0
COLLECT_CORE=0
COLLECT_SOURCE=
COLLECT_VACUUM=0

# Retention cleanup. A maintenance loop runs at MAINTENANCE_SCHEDULE when the
# schedule profile is enabled.
RETENTION_DAYS=30
MAINTENANCE_SCHEDULE=03:30
MAINTENANCE_VACUUM=1
MAX_ARTICLES=500

# SQLite waits reduce transient lock/open failures when API and collectors share
# the mounted database.
SQLITE_TIMEOUT=30
SQLITE_BUSY_TIMEOUT_MS=30000

# Docker build knobs.
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_DEFAULT_TIMEOUT=180
PIP_RETRIES=10
